# Luigi Taxi Environment Variables
# Copy this file to .env.local and fill in your values

# ===================
# Required for Production
# ===================

# Site URL (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://taxiluigi.at

# Google Site Verification (get from Google Search Console)
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your-google-verification-code

# ===================
# Contact / Booking
# ===================
# Forms open the visitor's own email client (mailto:) addressed to the
# business — no server-side email service is used.

# ===================
# Payment Processing
# ===================

# Stripe
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx

# ===================
# SMS Notifications (optional)
# ===================

# Twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+43xxxxxxxxxx

# ===================
# Database (optional - for booking storage)
# ===================

# PostgreSQL (Vercel Postgres, Supabase, etc.)
DATABASE_URL=postgresql://user:password@host:5432/database

# OR MongoDB
# MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/database

# ===================
# Maps & Distance Calculation (INTEGRATED)
# ===================

# Google Maps API Key (get from https://console.cloud.google.com/)
# Enable these APIs in Google Cloud Console:
# - Distance Matrix API
# - Geocoding API
# - Places API (for autocomplete)
# This enables:
# - Accurate distance calculation between locations
# - Real-time price estimation based on actual route distance
# - Travel time estimates
# - Address autocomplete in booking form
# Without this key, the system uses a fallback estimation
GOOGLE_MAPS_API_KEY=AIzaxxxxxxxxxxxxxxxx

# Public Google Maps API Key (same as above, used for client-side autocomplete)
# IMPORTANT: This key will be exposed to the browser
# Make sure to restrict it in Google Cloud Console:
# - HTTP referrers: *.taxiluigi.at/*, *.vercel.app/*, localhost/*
# - APIs: Distance Matrix API, Geocoding API, Places API
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIzaxxxxxxxxxxxxxxxx

# ===================
# Analytics (optional)
# ===================

# Google Analytics
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Vercel Analytics (automatically enabled on Vercel)
# No configuration needed

# ===================
# Logging & Monitoring (optional)
# ===================

# Sentry
SENTRY_DSN=https://xxxx@sentry.io/xxxx

# LogRocket
LOGROCKET_APP_ID=xxxxx/xxxxx

# ===================
# Development
# ===================

# Set to 'development' for local dev, 'production' for production
NODE_ENV=development

# Enable debug logging
DEBUG=false
