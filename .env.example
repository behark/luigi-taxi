# Luigi Taxi Environment Variables
# Copy this file to .env.local and fill in your values

# ===================
# Required for Production
# ===================

# Site URL (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://luigitaxi.at

# Google Site Verification (get from Google Search Console)
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your-google-verification-code

# ===================
# Email Service (choose one)
# ===================

# Resend (recommended)
RESEND_API_KEY=re_xxxxxxxxxxxx

# OR SendGrid
# SENDGRID_API_KEY=SG.xxxxxxxxxxxx

# OR Nodemailer SMTP
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-email@example.com
# SMTP_PASSWORD=your-password

# Email addresses
EMAIL_FROM=booking@luigitaxi.at
EMAIL_TO_ADMIN=info@luigitaxi.at

# ===================
# Payment Processing
# ===================

# Stripe
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx

# ===================
# SMS Notifications (optional)
# ===================

# Twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+43xxxxxxxxxx

# ===================
# Database (optional - for booking storage)
# ===================

# PostgreSQL (Vercel Postgres, Supabase, etc.)
DATABASE_URL=postgresql://user:password@host:5432/database

# OR MongoDB
# MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/database

# ===================
# Maps & Distance Calculation (optional)
# ===================

# Google Maps API (for accurate distance/price calculation)
GOOGLE_MAPS_API_KEY=AIzaxxxxxxxxxxxxxxxx

# ===================
# Analytics (optional)
# ===================

# Google Analytics
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Vercel Analytics (automatically enabled on Vercel)
# No configuration needed

# ===================
# Logging & Monitoring (optional)
# ===================

# Sentry
SENTRY_DSN=https://xxxx@sentry.io/xxxx

# LogRocket
LOGROCKET_APP_ID=xxxxx/xxxxx

# ===================
# Development
# ===================

# Set to 'development' for local dev, 'production' for production
NODE_ENV=development

# Enable debug logging
DEBUG=false
